{
  "description": "Release/package denylist. Keep in sync with packages/shared/src/security/denylist.ts.",
  "blockedPaths": [
    "context_store/credentials.md",
    "context_store/",
    ".codex/",
    ".codegraph/",
    "archives/",
    ".runtime/",
    "runtime/",
    "node_modules/",
    "dist/",
    "build/",
    "out/",
    "coverage/",
    "cache/",
    "logs/",
    "backups/",
    "browser-profiles/",
    "profiles/",
    "release/",
    "releases/",
    "artifacts/",
    "tmp/",
    "temp/",
    "updater-staging/",
    "staging/",
    "update-backups/"
  ],
  "blockedGlobs": [
    "**/*credentials*",
    "**/*secret*",
    "**/*.db",
    "**/*.sqlite",
    "**/*.sqlite3",
    "**/*.db-wal",
    "**/*.db-shm",
    "**/*.log",
    "**/*.zip",
    "**/*.7z",
    "**/*.rar",
    "**/*.pem",
    "**/*.key",
    "**/*.pfx",
    "**/*.p12"
  ]
}
