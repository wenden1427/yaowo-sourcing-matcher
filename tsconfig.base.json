{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@yaowo/core": ["packages/core/src/index.ts"],
      "@yaowo/db": ["packages/db/src/index.ts"],
      "@yaowo/shared": ["packages/shared/src/index.ts"]
    }
  }
}
